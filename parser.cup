    Statements s = new Statements();
    String handleA = a.getHandle();
    if (handleA == null) typeError("Expression does not produce a value", a);
    String handleB = b.getHandle();
    if (handleB == null) typeError("Expression does not produce a value", b);
    s.appendStatements(a);
    s.appendStatements(b);
    s.statements.add(new DualOperationValueStatement(handleA, handleB, DualOperationValueStatement.Operation.INEQUALITY));
    RESULT = s;
:};

