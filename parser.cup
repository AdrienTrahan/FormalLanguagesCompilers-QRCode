    RESULT = s;
:};

line ::= NAME:name DIV_ASSIGNMENT value:val SEMICOLON {:
    String handle = val.getHandle();
    if (handle == null) typeError("Expression does not produce a value", val);

    Statements s = new Statements();
    s.appendStatements(val);
    VariableValueStatement namedVariable = new VariableValueStatement(name);
    s.statements.add(namedVariable);
    DualOperationValueStatement operation = new DualOperationValueStatement(namedVariable.handle, handle, DualOperationValueStatement.Operation.DIV);
    s.statements.add(operation);
    AssignmentStatement assignment = new AssignmentStatement(name, operation.handle);
    s.statements.add(assignment);

    RESULT = s;
:};