    Statements s = new Statements();
    s.appendStatements(val);
    VariableValueStatement namedVariable = new VariableValueStatement(name);
    s.statements.add(namedVariable);
    DualOperationValueStatement operation = new DualOperationValueStatement(namedVariable.handle, handle, DualOperationValueStatement.Operation.MUL);
    s.statements.add(operation);
    AssignmentStatement assignment = new AssignmentStatement(name, operation.handle);
