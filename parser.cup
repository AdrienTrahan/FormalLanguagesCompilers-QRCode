value ::= NAME:name {:
    Statements s = new Statements();
    Statement newStatement = new VariableValueStatement(name);
    s.statements.add(newStatement);
    RESULT = s;
:};

line ::= NAME:name ASSIGNMENT value:val SEMICOLON {:

    Statements s = new Statements();
    String handle = val.getHandle();
    if (handle == null) typeError("Expression does not produce a value", val);
    
    parser.variableNameMap.put(name, generateTempVariableName());
    Statement newStatement = new AssignmentStatement(name, handle);
    s.appendStatements(val);
    s.statements.add(newStatement);
    RESULT = s;
:};

line ::= NAME:name OPEN_PARENTHESIS CLOSE_PARENTHESIS SEMICOLON {:
    Statements s = new Statements();
    s.statements.add(new GotoStatement(name));
    RESULT = s;
:};

line ::= IF OPEN_PARENTHESIS value:val CLOSE_PARENTHESIS DOT THEN OPEN_PARENTHESIS block:block_name CLOSE_PARENTHESIS SEMICOLON{:
    Statements s = new Statements();
    String handle = val.getHandle();
    if (handle == null) typeError("Expression does not produce a value", val);
    
    Statement newStatement = new ConditionalGotoStatement(handle, block_name);
    s.appendStatements(val);
    s.statements.add(newStatement);
    RESULT = s;
:};

line ::= IF OPEN_PARENTHESIS value:val CLOSE_PARENTHESIS DOT THEN OPEN_PARENTHESIS block:block_name_a CLOSE_PARENTHESIS DOT ELSE OPEN_PARENTHESIS block:block_name_b CLOSE_PARENTHESIS SEMICOLON{:
    Statements s = new Statements();
    String handle = val.getHandle();
    if (handle == null) typeError("Expression does not produce a value", val);
    
    Statement newStatement = new ConditionalGotoStatement(handle, block_name_a, block_name_b);
    s.appendStatements(val);
    s.statements.add(newStatement);
    RESULT = s;
:};


line ::= WHILE OPEN_PARENTHESIS value:val CLOSE_PARENTHESIS DOT THEN OPEN_PARENTHESIS block:block_name CLOSE_PARENTHESIS SEMICOLON {:
    String handle = val.getHandle();
    if (handle == null) typeError("Expression does not produce a value", val);
    
    String newBlock = generateTempBlockName();
    Statements s = new Statements();

    s.appendStatements(val);
    Statement newStatement = new ConditionalGotoStatement(handle, block_name);
    s.statements.add(newStatement);
    parser.blocksTable.put(newBlock, s);

    parser.blocksTable.get(block_name).statements.add(new GotoStatement(newBlock));

    RESULT = s;
:};

line ::= NAME:name PLUS_ASSIGNMENT value:val SEMICOLON {:
    String handle = val.getHandle();
    if (handle == null) typeError("Expression does not produce a value", val);

    Statements s = new Statements();
    s.appendStatements(val);
    VariableValueStatement namedVariable = new VariableValueStatement(name);
    s.statements.add(namedVariable);
    DualOperationValueStatement operation = new DualOperationValueStatement(namedVariable.handle, handle, DualOperationValueStatement.Operation.PLUS);
    s.statements.add(operation);
    AssignmentStatement assignment = new AssignmentStatement(name, operation.handle);
    s.statements.add(assignment);

    RESULT = s;
:};

line ::= NAME:name MINUS_ASSIGNMENT value:val SEMICOLON {:
    String handle = val.getHandle();
    if (handle == null) typeError("Expression does not produce a value", val);

    Statements s = new Statements();
    s.appendStatements(val);
    VariableValueStatement namedVariable = new VariableValueStatement(name);
    s.statements.add(namedVariable);
    DualOperationValueStatement operation = new DualOperationValueStatement(namedVariable.handle, handle, DualOperationValueStatement.Operation.MINUS);
    s.statements.add(operation);
    AssignmentStatement assignment = new AssignmentStatement(name, operation.handle);
    s.statements.add(assignment);

    RESULT = s;
:};

line ::= NAME:name MUL_ASSIGNMENT value:val SEMICOLON {:
    String handle = val.getHandle();
